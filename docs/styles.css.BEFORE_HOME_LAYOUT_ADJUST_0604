:root{
  --paper:#d8c39b;
  --paper-light:#eadbbd;
  --paper-dark:#b79d70;
  --ink:#10100e;
  --muted:#625740;
  --line:#8c7a55;
  --panel:#fffdf7;
  --green:#31472b;
  --green-dark:#1d2a1a;
  --red:#b92318;
  --blue:#2367e8;
  --yellow:#f2c84b;
  --confirmed:#2f7d32;
  --white:#ffffff;
  --radius:6px;
  --shadow:0 16px 36px rgba(33,25,10,.18);
}

*{
  box-sizing:border-box;
  -webkit-tap-highlight-color:transparent;
}

html{
  -webkit-text-size-adjust:100%;
  text-size-adjust:100%;
}

body{
  margin:0;
  color:var(--ink);
  font-family:Arial, Helvetica, sans-serif;
  background:
    linear-gradient(90deg, rgba(16,16,14,.045) 1px, transparent 1px),
    linear-gradient(rgba(16,16,14,.035) 1px, transparent 1px),
    var(--paper-light);
  background-size:34px 34px;
}

a{color:inherit}

.shell{
  width:min(1220px, calc(100% - 28px));
  min-height:100vh;
  margin:0 auto;
  padding:8px 0 28px;
}

.m4-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;
  padding:6px 8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  color:var(--ink);
  background:var(--paper);
  box-shadow:var(--shadow);
}

.brand-lockup{
  display:grid;
  gap:2px;
}

.vendor-slot{
  display:flex;
  align-items:center;
  gap:7px;
  min-width:0;
}

.vendor-slot img{
  width:30px;
  height:30px;
  object-fit:cover;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--paper-light);
}

.vendor-name{
  color:var(--ink);
  font-size:13px;
  font-weight:900;
  text-decoration:none;
}

.vendor-name:hover{
  text-decoration:underline;
}

.vendor-minor-link{
  color:var(--muted);
  font-size:11px;
  font-weight:900;
  text-decoration:none;
  text-transform:uppercase;
}

.vendor-minor-link:hover{
  color:var(--ink);
  text-decoration:underline;
}

.kicker{
  color:var(--green-dark);
  font-size:10px;
  font-weight:900;
  letter-spacing:.08em;
  text-transform:uppercase;
}

h1,h2,h3,p{margin-top:0}

h1{
  margin-bottom:4px;
  font-size:clamp(24px, 3.4vw, 42px);
  line-height:1;
  letter-spacing:0;
}

h2{
  margin-bottom:6px;
  font-size:19px;
}

p{
  color:var(--muted);
  line-height:1.5;
}

.nav{
  display:flex;
  flex-wrap:wrap;
  gap:6px;
  justify-content:flex-end;
}

.locked-nav{
  display:flex;
  flex-wrap:wrap;
  gap:5px;
  justify-content:flex-end;
  align-items:center;
}

.locked-nav-item{
  display:inline-flex;
  align-items:center;
  gap:6px;
  min-height:30px;
  padding:5px 8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--panel);
  color:var(--ink);
  font-size:11px;
  font-weight:900;
  text-decoration:none;
  text-transform:uppercase;
  touch-action:manipulation;
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
}

.locked-nav-item.is-active{
  background:#eef4ff;
  border-color:var(--blue);
}

.nav-dot{
  width:8px;
  height:8px;
  flex:0 0 8px;
  border-radius:50%;
  background:#8b8b8b;
  box-shadow:0 0 0 2px rgba(16,16,14,.12);
}

.locked-nav-item.is-active .nav-dot{
  background:var(--blue);
}

.target-nav-icon{
  position:relative;
  width:16px;
  height:16px;
  flex:0 0 16px;
  border:2px solid var(--red);
  border-radius:50%;
}

.target-nav-icon::before{
  content:"";
  position:absolute;
  left:50%;
  top:50%;
  width:6px;
  height:6px;
  border-radius:50%;
  background:var(--red);
  transform:translate(-50%,-50%);
}

.target-nav-icon::after{
  content:"";
  position:absolute;
  right:-8px;
  top:0;
  width:10px;
  height:3px;
  border-radius:999px;
  background:var(--red);
  transform:rotate(-38deg);
  transform-origin:left center;
}

.button,
button{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-height:40px;
  padding:9px 12px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--panel);
  color:var(--ink);
  font-weight:900;
  text-decoration:none;
  text-transform:uppercase;
  font-size:13px;
  cursor:pointer;
  touch-action:manipulation;
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
}

.button:active,
button:active,
.locked-nav-item:active,
.category-pill:active{
  transform:translateY(1px);
}

.button.primary{
  background:var(--green);
  border-color:var(--green-dark);
  color:white;
}

.button.caution{background:var(--yellow)}
.button.correction{background:var(--red); color:white}
.button.confirmed{background:var(--confirmed); color:white}

.workflow-control-row{
  display:flex;
  flex-wrap:nowrap;
  gap:6px;
  align-items:center;
  padding:8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--paper);
  position:sticky;
  top:8px;
  z-index:2;
  overflow:visible;
}

.workflow-control-row .button{
  flex:1 1 0;
  min-width:0;
  min-height:42px;
  padding:8px 6px;
  background:var(--panel);
  color:var(--ink);
  font-size:clamp(10px, 1.05vw, 13px);
  line-height:1.1;
  text-align:center;
  white-space:normal;
}

.workflow-control-row .button[disabled]{
  opacity:1;
}

.workflow-control-row .button.next-step,
.neon-file-button.next-step{
  background:#39ff14;
  border-color:#173f12;
  color:#0c2608;
}

.visually-hidden-file{
  position:absolute;
  inline-size:1px;
  block-size:1px;
  opacity:0;
  pointer-events:none;
}

.status-pills{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin:12px 0 16px;
}

.status-pill{
  display:inline-flex;
  align-items:center;
  min-height:34px;
  padding:7px 10px;
  border:2px solid var(--ink);
  border-radius:999px;
  background:var(--paper);
  color:var(--ink);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}

.active-session-bar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;
  margin-top:6px;
  padding:5px 8px;
  min-height:24px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--green);
  color:var(--white);
  box-shadow:var(--shadow);
}

.active-session-bar strong{
  visibility:visible;
  font-size:13px;
  text-transform:uppercase;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.active-session-bar span{
  visibility:visible;
  font-size:10px;
  font-weight:900;
  text-transform:uppercase;
  white-space:nowrap;
}

.button[disabled]{
  opacity:.45;
  cursor:not-allowed;
}

.target-hero{
  display:grid;
  grid-template-columns:minmax(280px,430px) minmax(0,1fr);
  gap:18px;
  align-items:start;
  margin-top:16px;
}

.target-board{
  padding:12px;
  border:3px solid var(--ink);
  border-radius:var(--radius);
  background:var(--paper);
  box-shadow:var(--shadow);
}

.target-board img{
  display:block;
  width:100%;
  border:2px solid var(--ink);
  background:var(--paper);
}

.target-caption{
  display:flex;
  justify-content:space-between;
  gap:10px;
  margin-top:10px;
  color:var(--ink);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}

.hero-copy,
.panel{
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--panel);
  box-shadow:var(--shadow);
}

.hero-copy{
  padding:18px;
}

.doctrine-strip{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:8px;
  margin:14px 0;
}

.doctrine-strip div,
.badge,
.metric{
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--paper-light);
  padding:10px;
}

.doctrine-strip span,
.metric span{
  display:block;
  color:var(--muted);
  font-size:11px;
  font-weight:900;
  text-transform:uppercase;
}

.doctrine-strip strong,
.metric strong{
  display:block;
  margin-top:3px;
  color:var(--ink);
  font-size:18px;
}

.qr-callout{
  display:grid;
  grid-template-columns:92px 1fr;
  gap:12px;
  align-items:center;
  margin:14px 0;
  padding:12px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--paper);
}

.qr-box{
  display:grid;
  place-items:center;
  width:92px;
  aspect-ratio:1;
  border:5px solid var(--ink);
  background:
    linear-gradient(90deg,#111 24%,transparent 24% 38%,#111 38% 52%,transparent 52% 70%,#111 70%),
    linear-gradient(#fff,#fff);
  color:#111;
  font-size:11px;
  font-weight:900;
}

.journey{
  display:grid;
  grid-template-columns:repeat(7,minmax(0,1fr));
  gap:6px;
  margin-top:16px;
}

.journey a,
.journey span{
  display:grid;
  place-items:center;
  min-height:44px;
  padding:8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--paper-light);
  font-size:12px;
  font-weight:900;
  text-align:center;
  text-decoration:none;
}

.journey .active{
  background:var(--green);
  color:white;
}

.grid{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:12px;
  margin-top:16px;
}

.panel{
  padding:12px;
}

.operational-home .hero-copy{
  align-self:stretch;
}

.mission-cards,
.action-grid,
.session-summary{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:10px;
  margin:14px 0;
}

.shoot-workflow{
  margin-top:8px;
}

.matrix-only{
  margin-top:8px;
}

.shoot-workflow > .panel{
  display:grid;
  gap:6px;
}

.shoot-workflow h1{
  margin-bottom:0;
  font-size:clamp(18px, 2.1vw, 28px);
}

.upload-panel{
  display:grid;
  gap:6px;
  margin:4px 0;
  padding:8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:#fffaf0;
}

.upload-panel h2{
  margin-bottom:4px;
}

.evidence-preview{
  display:grid;
  grid-template-columns:minmax(260px, min(72vw, 720px)) minmax(180px,1fr);
  gap:12px;
  align-items:center;
  min-height:112px;
  padding:10px;
  border:2px dashed var(--line);
  border-radius:var(--radius);
  background:var(--panel);
}

.evidence-preview.evidence-workspace{
  grid-template-columns:minmax(320px, min(76vw, 820px)) minmax(220px,1fr);
  align-items:stretch;
  height:720px;
  min-height:720px;
  overflow:hidden;
}

.evidence-meta{
  display:grid;
  align-content:start;
  gap:12px;
  padding:12px;
  min-height:0;
  overflow:auto;
}

.evidence-meta strong,
.evidence-meta span{
  display:block;
  line-height:1.35;
}

.evidence-meta strong{
  overflow-wrap:anywhere;
}

.evidence-status-stack{
  gap:16px;
}

.target-intel-stack{
  display:grid;
  gap:8px;
  align-content:start;
}

.target-intel-distance,
.target-intel-item,
.target-intel-score{
  display:grid;
  align-items:center;
  min-height:42px;
  padding:7px 9px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--panel);
}

.target-intel-distance{
  gap:7px;
}

.target-intel-distance > strong{
  color:var(--ink);
  font-size:18px;
  line-height:1;
  text-transform:lowercase;
}

.target-distance-unit-toggle{
  margin:0;
}

.target-intel-distance select{
  min-height:30px;
  padding:4px 26px 4px 8px;
  border-width:1px;
  font-size:16px;
  font-weight:900;
}

.distance-other-input.is-hidden{
  display:none;
}

.target-intel-item strong{
  color:var(--ink);
  font-size:18px;
  line-height:1;
}

.target-intel-score{
  place-items:center;
  color:var(--white);
  text-align:center;
  min-height:76px;
}

.target-intel-score strong{
  font-size:clamp(38px, 6vw, 64px);
  line-height:.9;
}

.guidance-card{
  display:grid;
  gap:8px;
  padding-top:10px;
  border-top:2px solid var(--ink);
}

.guidance-card summary,
.custom-distance-card summary{
  color:var(--ink);
  font-size:13px;
  font-weight:900;
  text-transform:uppercase;
  cursor:pointer;
  touch-action:manipulation;
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
}

.guidance-list{
  display:grid;
  gap:5px;
  margin-top:8px;
  color:var(--ink);
  font-size:12px;
  font-weight:900;
  line-height:1.2;
}

.custom-distance-card{
  display:grid;
  gap:8px;
  margin-top:10px;
  padding-top:8px;
  border-top:1px solid var(--line);
}

.custom-distance-card label{
  margin-top:8px;
}

.unit-toggle{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:6px;
  margin:8px 0;
}

.unit-button{
  min-height:34px;
  padding:5px 8px;
  background:var(--panel);
}

.unit-button.is-active{
  background:var(--green);
  border-color:var(--green-dark);
  color:var(--white);
}

.guidance-calc-button{
  width:100%;
  min-height:36px;
}

.guidance-result{
  margin-top:8px;
  padding:8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--paper);
  color:var(--ink);
  font-size:18px;
  font-weight:900;
  text-align:center;
}

.evidence-preview img{
  width:100%;
  max-height:78vh;
  object-fit:contain;
  border:2px solid var(--ink);
  background:var(--paper);
}

.mark-surface{
  position:relative;
  display:block;
  width:100%;
  max-width:820px;
  height:100%;
  min-height:0;
  contain:layout paint;
  touch-action:none;
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
  overscroll-behavior:contain;
}

.mark-surface img{
  display:block;
  width:100%;
  height:100%;
  min-height:0;
  object-fit:contain;
  pointer-events:none;
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
}

.marker-layer{
  position:absolute;
  inset:0;
  pointer-events:none;
}

.target-marker{
  position:absolute;
  display:grid;
  place-items:center;
  width:14px;
  height:14px;
  translate:-50% -50%;
  border:2px solid var(--ink);
  border-radius:50%;
  color:var(--white);
  font-size:9px;
  font-weight:900;
  line-height:1;
  box-shadow:0 2px 8px rgba(0,0,0,.28);
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
}

.aim-marker{
  width:18px;
  height:18px;
  background:transparent;
  border-color:var(--confirmed);
  color:var(--confirmed);
}

.aim-marker::before,
.aim-marker::after{
  content:"";
  position:absolute;
  background:var(--confirmed);
}

.aim-marker::before{
  width:24px;
  height:2px;
}

.aim-marker::after{
  width:2px;
  height:24px;
}

.impact-marker{
  background:var(--red);
}

.mark-status{
  padding:10px;
  border:2px dashed var(--line);
  border-radius:var(--radius);
  background:var(--panel);
  color:var(--muted);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}

.evidence-preview span{
  color:var(--muted);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}

.page-layout{
  display:grid;
  grid-template-columns:minmax(280px,420px) minmax(0,1fr);
  gap:16px;
  align-items:start;
  margin-top:16px;
}

.placeholder-list{
  display:grid;
  gap:9px;
  padding:0;
  margin:0;
  list-style:none;
}

.placeholder-list li{
  padding:11px;
  border:2px dashed var(--line);
  border-radius:var(--radius);
  background:#fffaf0;
  font-weight:800;
}

.matrix-grid,
.status-row{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
  gap:10px;
}

.category-pill-row{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
}

.category-pill{
  min-width:112px;
  background:var(--panel);
  touch-action:manipulation;
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
}

.category-pill.is-active{
  background:var(--green);
  border-color:var(--green-dark);
  color:var(--white);
}

.target-session-controls{
  display:flex;
  align-items:center;
  gap:8px;
}

.target-session-controls label{
  display:flex;
  align-items:center;
  gap:8px;
  color:var(--ink);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}

.target-session-controls select{
  min-height:32px;
  padding:5px 28px 5px 8px;
}

.setup-summary-panel{
  display:grid;
  gap:8px;
  padding:12px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:#fffaf0;
}

.setup-summary-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:8px;
}

.target-setup-strip{
  margin:10px 0;
}

.target-setup-strip .results-grid{
  padding-top:8px;
  border-top:2px solid var(--ink);
}

.field-shell{
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:#fffaf0;
  padding:12px;
}

.field-shell.caution-state{
  background:#fff3c9;
}

.field-shell.success-state{
  background:#e3f1dd;
}

.field-shell span{
  display:block;
  color:var(--muted);
  font-size:11px;
  font-weight:900;
  text-transform:uppercase;
}

.field-shell strong{
  display:block;
  margin-top:5px;
  font-size:18px;
}

.home-card-details{
  display:grid;
  gap:6px;
  margin-top:8px;
}

.home-card-details > strong{
  margin-top:0;
}

.home-detail-row{
  display:grid;
  grid-template-columns:minmax(72px,.65fr) minmax(0,1fr);
  gap:8px;
  align-items:baseline;
}

.home-detail-row span{
  font-size:10px;
}

.home-detail-row strong{
  margin:0;
  font-size:15px;
  line-height:1.2;
}

.footer-note{
  margin-top:16px;
  color:var(--muted);
  font-size:13px;
  font-weight:800;
}

.matrix-form{
  display:grid;
  gap:10px;
}

.matrix-form h1{
  font-size:clamp(24px, 3.2vw, 40px);
}

.form-section{
  display:grid;
  gap:10px;
  padding:12px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:#fffaf0;
}

.form-section h2,
.section-heading h1{
  margin-bottom:0;
}

label{
  display:grid;
  gap:5px;
  color:var(--muted);
  font-size:11px;
  font-weight:900;
  text-transform:uppercase;
}

label.is-hidden{
  display:none;
}

.optional-label{
  color:var(--muted);
  font-weight:900;
}

input,
select,
textarea{
  width:100%;
  min-height:40px;
  padding:8px 10px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--white);
  color:var(--ink);
  font:inherit;
  font-size:16px;
  font-weight:800;
  touch-action:manipulation;
}

label,
.metric,
.history-card,
.setup-summary-panel,
.results-panel{
  -webkit-touch-callout:none;
}

label{
  user-select:none;
  -webkit-user-select:none;
}

input,
textarea{
  user-select:text;
  -webkit-user-select:text;
}

textarea{
  resize:vertical;
}

input[readonly]{
  background:var(--paper-light);
}

.history-panel{
  margin-top:6px;
}

.history-list{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(520px,1fr));
  gap:8px;
  margin-top:6px;
}

.history-card{
  display:grid;
  grid-template-columns:88px minmax(0,1fr);
  align-items:stretch;
  gap:8px;
  height:116px;
  padding:7px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:#fffaf0;
  overflow:hidden;
}

.history-card.no-thumb{
  grid-template-columns:1fr;
  height:auto;
}

.history-thumb{
  position:relative;
  width:88px;
  height:100%;
}

.history-card > img{
  width:min(220px, 100%);
}

.history-card img,
.history-thumb img{
  width:100%;
  height:100%;
  border:2px solid var(--ink);
  background:var(--paper);
  object-fit:cover;
  aspect-ratio:3/4;
}

.history-copy{
  display:grid;
  grid-template-rows:auto auto 1fr;
  gap:4px;
  min-height:0;
  overflow:hidden;
}

.history-title{
  display:flex;
  justify-content:space-between;
  gap:6px;
  color:var(--ink);
  font-weight:900;
  line-height:1;
}

.history-title strong{
  white-space:nowrap;
}

.history-title span{
  color:var(--muted);
  font-size:11px;
  text-align:right;
  white-space:nowrap;
}

.sec-heading{
  display:flex;
  align-items:start;
  justify-content:space-between;
  gap:10px;
}

.sec-heading h1{
  line-height:.9;
}

.sec-heading h2{
  margin:3px 0 0;
  font-size:16px;
}

.vendor-pill{
  display:inline-flex;
  align-items:center;
  gap:6px;
  min-height:30px;
  padding:4px 8px;
  border:2px solid var(--ink);
  border-radius:999px;
  background:var(--paper);
  color:var(--ink);
  font-size:11px;
  font-weight:900;
  text-decoration:none;
  text-transform:uppercase;
  touch-action:manipulation;
  user-select:none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
}

.sec-heading .vendor-pill{
  margin-left:auto;
}

.sec-heading .vendor-pill + .vendor-pill{
  margin-left:0;
}

.save-page-button{
  cursor:pointer;
}

.vendor-pill img{
  width:22px;
  height:22px;
  border:1px solid var(--ink);
  border-radius:50%;
  object-fit:cover;
}

.poib-dot{
  position:absolute;
  left:50%;
  top:50%;
  translate:-50% -50%;
  display:grid;
  place-items:center;
  width:11px;
  height:11px;
  border:2px solid var(--confirmed);
  border-radius:50%;
  background:rgba(255,253,247,.9);
  pointer-events:none;
}

.poib-dot span{
  width:3px;
  height:3px;
  border-radius:50%;
  background:var(--confirmed);
}

.aim-arrow{
  position:absolute;
  left:50%;
  top:50%;
  width:13px;
  height:2px;
  translate:-50% -50%;
  rotate:var(--aim-angle);
  border-radius:999px;
  background:var(--blue);
  pointer-events:none;
}

.aim-arrow::after{
  content:"";
  position:absolute;
  right:-1px;
  top:50%;
  width:5px;
  height:5px;
  border-right:2px solid var(--blue);
  border-top:2px solid var(--blue);
  transform:translateY(-50%) rotate(45deg);
}

.sec-setup-line{
  overflow:hidden;
  color:var(--muted);
  font-size:10px;
  font-weight:900;
  line-height:1.1;
  text-overflow:ellipsis;
  text-transform:uppercase;
  white-space:nowrap;
}

.sec-attribution-line{
  overflow:hidden;
  color:var(--muted);
  font-size:9px;
  font-weight:900;
  line-height:1.1;
  text-overflow:ellipsis;
  text-transform:uppercase;
  white-space:nowrap;
}

.sec-intel-pill{
  display:grid;
  grid-template-columns:minmax(70px,.8fr) minmax(74px,.9fr) minmax(118px,1.2fr) minmax(54px,.6fr);
  align-items:center;
  gap:4px;
  min-height:40px;
  padding:4px;
  border:2px solid var(--ink);
  border-radius:999px;
  background:var(--panel);
  color:var(--ink);
  font-size:12px;
  font-weight:900;
  line-height:1;
  text-align:center;
}

.sec-score{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:3px;
  min-height:30px;
  padding:2px 5px;
  border-radius:999px;
  color:var(--white);
}

.sec-score strong{
  font-size:22px;
  line-height:.9;
}

.sec-clicks{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  min-height:30px;
  padding:2px 6px;
  border-radius:999px;
  background:var(--paper);
  color:var(--ink);
}

.sec-clicks strong{
  min-width:24px;
  font-size:18px;
  line-height:1;
}

.sec-clicks em{
  color:var(--muted);
  font-size:10px;
  font-style:normal;
  font-weight:900;
  letter-spacing:.03em;
}

.compact-metrics{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(130px,1fr));
  gap:6px;
}

.compact-metrics span{
  padding:7px;
  border:1px solid var(--line);
  border-radius:var(--radius);
  background:var(--panel);
  color:var(--muted);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}

.compact-metrics strong{
  color:var(--ink);
}

.empty-state{
  grid-template-columns:1fr;
}

.results-panel{
  display:grid;
  gap:8px;
  margin:8px 0;
  padding:8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:#fffaf0;
}

.results-grid,
.target-data-row{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
  gap:8px;
}

.target-data-row{
  grid-template-columns:minmax(120px,.9fr) minmax(82px,.7fr) minmax(90px,.7fr) minmax(90px,.7fr) minmax(90px,.7fr);
  align-items:stretch;
}

.target-data-distance,
.target-data-item,
.target-data-score{
  display:grid;
  align-content:center;
  min-height:48px;
  padding:6px 8px;
  border:2px solid var(--ink);
  border-radius:var(--radius);
  background:var(--panel);
}

.target-data-distance{
  gap:4px;
}

.target-data-distance span,
.target-data-item span{
  color:var(--muted);
  font-size:10px;
  font-weight:900;
  text-transform:uppercase;
}

.target-data-distance select{
  min-height:28px;
  padding:3px 24px 3px 6px;
  border-width:1px;
  font-size:14px;
}

.target-data-item strong{
  color:var(--ink);
  font-size:18px;
  line-height:1;
}

.target-data-score{
  place-items:center;
  color:var(--white);
  text-align:center;
}

.target-data-score strong{
  font-size:clamp(30px, 5vw, 48px);
  line-height:.9;
}

.score-pending{
  background:var(--muted);
}

.score-green{
  background:var(--confirmed);
}

.score-yellow{
  background:var(--yellow);
  color:var(--ink);
}

.score-orange{
  background:#f28c28;
  color:var(--ink);
}

.score-red{
  background:var(--red);
}

.session-modal{
  position:fixed;
  inset:0;
  display:none;
  place-items:center;
  padding:20px;
  background:rgba(16,16,14,.48);
  z-index:10;
}

.session-modal.is-open{
  display:grid;
}

.session-modal .panel{
  width:min(720px, 100%);
  max-height:85vh;
  overflow:auto;
}

.session-detail-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(170px,1fr));
  gap:10px;
}

@media (max-width:900px){
  .m4-header,
  .target-hero,
  .page-layout{
    display:grid;
    grid-template-columns:1fr;
  }

  .journey,
  .grid,
  .doctrine-strip{
    grid-template-columns:1fr;
  }

  .history-card{
    grid-template-columns:72px minmax(0,1fr);
    gap:6px;
    height:104px;
    padding:5px;
  }

  .history-list{
    grid-template-columns:1fr;
  }

  .history-card > img{
    width:min(160px, 100%);
  }

  .history-thumb{
    width:72px;
  }

  .history-title{
    gap:4px;
  }

  .history-title strong{
    font-size:12px;
  }

  .history-title span{
    font-size:9px;
  }

  .sec-setup-line{
    font-size:8px;
  }

  .sec-intel-pill{
    grid-template-columns:minmax(42px,.8fr) minmax(58px,.9fr) minmax(76px,1.1fr) minmax(40px,.6fr);
    gap:2px;
    min-height:34px;
    padding:3px;
    font-size:9px;
  }

  .sec-score{
    min-height:26px;
    padding:2px 4px;
  }

  .sec-score strong{
    font-size:18px;
  }

  .sec-clicks{
    gap:4px;
    min-height:26px;
    padding:2px 4px;
  }

  .sec-clicks strong{
    min-width:18px;
    font-size:14px;
  }

  .sec-clicks em{
    font-size:8px;
  }

  .vendor-pill{
    min-height:28px;
    padding:3px 6px;
    font-size:10px;
  }

  .vendor-pill img{
    width:18px;
    height:18px;
  }

  .sec-heading{
    display:grid;
    grid-template-columns:1fr auto auto;
    align-items:center;
    gap:6px;
  }

  .sec-heading .vendor-pill{
    margin-left:0;
  }

  .save-page-button{
    white-space:nowrap;
  }

  .evidence-preview{
    grid-template-columns:1fr;
  }

  .evidence-preview.evidence-workspace{
    height:auto;
    min-height:0;
    overflow:visible;
  }

  .mark-surface,
  .mark-surface img{
    height:auto;
    min-height:0;
  }

  .evidence-preview img{
    width:100%;
  }

  .target-data-row{
    grid-template-columns:minmax(78px,.9fr) minmax(58px,.8fr) repeat(3,minmax(50px,.7fr));
    gap:4px;
  }

  .target-data-distance,
  .target-data-item,
  .target-data-score{
    min-height:42px;
    padding:5px;
  }

  .target-data-distance span,
  .target-data-item span{
    font-size:8px;
  }

  .target-data-distance select{
    font-size:12px;
    padding-inline:4px;
  }

  .target-data-item strong{
    font-size:14px;
  }

  .target-data-score strong{
    font-size:clamp(24px, 8vw, 34px);
  }
}


.vendor-minor-link{
  color: #1f7a35;
}

.vendor-minor-link:hover{
  color: #145725;
}

.operational-home .hero-copy{
  position: relative;
}

.home-survey-button{
  position: absolute;
  right: 0;
  bottom: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 124px;
  min-height: 48px;
  padding: 0.7rem 1.1rem;
  border: 3px solid #111;
  border-radius: 8px;
  background: var(--paper-light);
  color: var(--ink);
  font-weight: 900;
  text-transform: uppercase;
  text-decoration: none;
  box-shadow: 0 2px 0 rgba(0, 0, 0, 0.35);
}

.home-survey-button:hover{
  background: var(--paper-light);
}

.distance-setup-grid{
  align-items: end;
}

@media (max-width: 760px){
  .shell{
    width:min(100% - 14px, 1220px);
    padding-top:6px;
  }

  .target-board{
    padding:8px;
  }

  .operational-home .target-board img{
    max-height:52vh;
    object-fit:contain;
  }

  .target-caption{
    display:grid;
    grid-template-columns:1fr;
    gap:3px;
    margin-top:6px;
    font-size:9px;
    line-height:1.12;
  }

  .hero-copy{
    padding:12px;
  }

  .hero-copy h1{
    font-size:clamp(26px, 9vw, 36px);
  }

  .workflow-control-row{
    overflow-x:auto;
    overflow-y:hidden;
    -webkit-overflow-scrolling:touch;
    overscroll-behavior-x:contain;
    padding:6px;
    scrollbar-width:none;
  }

  .workflow-control-row::-webkit-scrollbar{
    display:none;
  }

  .workflow-control-row .button{
    flex:0 0 auto;
    min-width:112px;
    min-height:42px;
    padding:8px 10px;
  }

  .upload-panel{
    padding:6px;
  }

  .evidence-preview{
    padding:6px;
    gap:8px;
    max-width:100%;
    overflow:hidden;
  }

  .evidence-meta{
    padding:8px;
  }

  .target-intel-stack{
    gap:6px;
  }

  .guidance-card{
    gap:6px;
    padding-top:8px;
  }

  .matrix-form{
    gap:8px;
  }

  .matrix-form h1{
    font-size:clamp(28px, 10vw, 38px);
  }

  .form-section{
    gap:8px;
    padding:9px;
  }

  .matrix-grid{
    grid-template-columns:1fr;
    gap:8px;
  }

  input,
  select,
  textarea{
    min-height:38px;
    padding:7px 9px;
  }

  .category-pill{
    min-width:96px;
    min-height:38px;
  }

  .action-grid{
    gap:8px;
    margin:10px 0;
  }

  .home-survey-button{
    position: static;
    width: 100%;
    margin-top: 1rem;
  }
}


.nav-separator{
  color: var(--ink);
  font-weight: 900;
}

.shooter-tip{
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  color: var(--ink);
  white-space: nowrap;
}

.shooter-tip.is-hidden{
  display: none;
}

.shooter-tip .tip-label{
  color: var(--blue);
  font-weight: 900;
}

#shooterTipText{
  color: var(--ink);
  font-weight: 900;
}
