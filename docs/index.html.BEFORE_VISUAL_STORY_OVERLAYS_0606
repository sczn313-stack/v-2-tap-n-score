</main>
<script src="app_state.js"></script>
<script>
const HOME_CONFIG = {
  vendorName: "Baker Smart Targets",
  targetName: "Baker 100 Yard Smart Target",
  targetImage: "assets/BAKER_ST_100YD_SMART_AUTHORITY_v1_ORIGINAL.png",
  examples: [
    {
      title: "SCZN3 100YD Test",
      date: "May 10, 2025 · 8:24 AM",
      weapon: ".308 Win",
      distance: "100 Yards",
      shots: "5 Shots",
      group: "0.82 MOA",
      poib: "0.4&quot; High, 0.2&quot; Left"
    },
    {
      title: "AR556 Zero Check",
      date: "May 9, 2025 · 3:15 PM",
      weapon: "5.56 NATO",
      distance: "100 Yards",
      shots: "5 Shots",
      group: "1.12 MOA",
      poib: "0.6&quot; Low, 0.3&quot; Right"
    },
    {
      title: "6.5 Creedmoor",
      date: "May 8, 2025 · 11:02 AM",
      weapon: "6.5 Creedmoor",
      distance: "300 Yards",
      shots: "5 Shots",
      group: "0.65 MOA",
      poib: "0.2&quot; High, 0.1&quot; Left"
    }
  ]
};

function formatDate(value) {
  if (!value) return "Recent session";
  return new Date(value).toLocaleString(undefined, {
    month: "short",
    day: "numeric",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit"
  });
}

function sessionToCard(session, index) {
  const snapshot = session && session.matrixSnapshot ? session.matrixSnapshot : {};
  const shotData = session && session.shotData ? session.shotData : {};
  const correction = session && session.correctionData ? session.correctionData : {};
  return {
    title: session ? (session.sessionLabel || SCZN3M4.formatSessionNumber(session.sessionNumber)) : HOME_CONFIG.examples[index].title,
    date: session ? formatDate(session.timestamp || session.createdAt) : HOME_CONFIG.examples[index].date,
    weapon: snapshot.modelCaliber || snapshot.rifle || HOME_CONFIG.examples[index].weapon,
    distance: snapshot.targetDistance || snapshot.distance || HOME_CONFIG.examples[index].distance,
    shots: `${shotData.shotCount || shotData.hits || HOME_CONFIG.examples[index].shots.replace(/\D/g, "") || 5} Shots`,
    group: session && shotData.groupSize ? shotData.groupSize : HOME_CONFIG.examples[index].group,
    poib: session && shotData.poibSummary ? shotData.poibSummary : HOME_CONFIG.examples[index].poib
  };
}

function renderRecentCards() {
  const sessions = (SCZN3M4.getSessionHistory ? SCZN3M4.getSessionHistory() : []).slice(0, 3);
  const cards = [0, 1, 2].map(index => sessionToCard(sessions[index], index));
  const grid = document.getElementById("recentSecGrid");
  grid.textContent = "";
  cards.forEach((card, index) => {
    const article = document.createElement("article");
    article.className = "recent-card";
    article.innerHTML = `
      <div class="recent-thumb" aria-hidden="true">
        <img src="${HOME_CONFIG.targetImage}" alt="" />
        <span class="recent-thumb-hole recent-hole-a"></span>
        <span class="recent-thumb-hole recent-hole-b"></span>
        <span class="recent-thumb-hole recent-hole-c"></span>
      </div>
      <div class="recent-copy">
        <strong>${card.title}</strong>
        <span>${card.date}</span>
        <span>✦ ${card.weapon}</span>
        <span>◉ ${card.distance}</span>
        <span>● ${card.shots}</span>
        <p>Group: <b>${card.group}</b><br />POIB: <b>${card.poib}</b></p>
      </div>`;
    if (index === 0) article.classList.add("is-mirror");
    grid.append(article);
  });
}

renderRecentCards();
</script>
</body>
</html>
