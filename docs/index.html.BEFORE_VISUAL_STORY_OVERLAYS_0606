      </a>
      <a class="resource-card" href="shoot.html">
        <span class="resource-icon target-resource" aria-hidden="true"></span>
        <strong>Target Library</strong>
        <em>View and use target templates</em>
      </a>
      <a class="resource-card" href="buy-targets.html">
        <span class="resource-icon baker-resource" aria-hidden="true"></span>
        <strong>Baker Smart Targets</strong>
        <em>Shop smart targets and accessories</em>
