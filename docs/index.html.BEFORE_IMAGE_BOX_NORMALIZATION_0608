<script src="app_state.js"></script>
<script>
const HOME_CONFIG = {
  vendorName: "Baker Smart Targets",
  targetName: "Baker 100 Yard Smart Target",
  targetImage: "assets/BAKER_ST_100YD_SMART_AUTHORITY_v1_ORIGINAL.png",
  fallbackEvidenceImage: "",
  approvedFallbackEvidence: {
    distance: "150 YDS",
    hits: "5 HITS",
    group: "Approved Baker preview",
    poibSummary: "Reference evidence preview",
    aim: { xPercent: 51.0, yPercent: 57.6 },
    poib: { xPercent: 21.6, yPercent: 28.4 },
    impacts: [
      { xPercent: 15.3, yPercent: 23.2 },
      { xPercent: 15.5, yPercent: 34.3 },
      { xPercent: 28.3, yPercent: 34.5 },
      { xPercent: 28.8, yPercent: 23.0 },
      { xPercent: 19.7, yPercent: 27.3 }
    ]
  },
  examples: [
    {
      title: "SCZN3 100YD Test",
      date: "May 10, 2025 · 8:24 AM",
      weapon: ".308 Win",
      distance: "100 Yards",
      shots: "5 Shots",
      group: "0.82 MOA",
      poib: "0.4&quot; High, 0.2&quot; Left"
    },
    {
      title: "AR556 Zero Check",
      date: "May 9, 2025 · 3:15 PM",
      weapon: "5.56 NATO",
      distance: "100 Yards",
      shots: "5 Shots",
      group: "1.12 MOA",
      poib: "0.6&quot; Low, 0.3&quot; Right"
    },
    {
      title: "6.5 Creedmoor",
      date: "May 8, 2025 · 11:02 AM",
      weapon: "6.5 Creedmoor",
      distance: "300 Yards",
      shots: "5 Shots",
      group: "0.65 MOA",
      poib: "0.2&quot; High, 0.1&quot; Left"
    }
  ]
};

function safePoint(point) {
  return SCZN3M4.UGEO.normalizePoint(point);
}

function compactClick(value, axis) {
  if (!value) return "Not calculated";
  const amount = String(value).match(/\d+/)?.[0] || "0";
  const upper = String(value).toUpperCase();
  if (axis === "elevation") {
    if (upper.includes("UP")) return `${amount} Clicks ↑`;
    if (upper.includes("DOWN")) return `${amount} Clicks ↓`;
  }
  if (axis === "windage") {
    if (upper.includes("RIGHT")) return `${amount} Clicks →`;
    if (upper.includes("LEFT")) return `${amount} Clicks ←`;
  }
  return `${amount} Clicks`;
}

function displayedHeroImageBox() {
  const frame = document.querySelector(".hero-target-frame");
  const image = document.getElementById("heroTargetImage");
  if (!frame || !image) return null;
  const frameRect = frame.getBoundingClientRect();
  const imageRect = image.getBoundingClientRect();
  const naturalWidth = image.naturalWidth || imageRect.width || 1;
  const naturalHeight = image.naturalHeight || imageRect.height || 1;
  const naturalRatio = naturalWidth / naturalHeight;
  const elementRatio = imageRect.width / imageRect.height;
  let width = imageRect.width;
  let height = imageRect.height;
  let left = imageRect.left;
  let top = imageRect.top;
  if (elementRatio > naturalRatio) {
    width = imageRect.height * naturalRatio;
    left = imageRect.left + ((imageRect.width - width) / 2);
  } else {
    height = imageRect.width / naturalRatio;
    top = imageRect.top + ((imageRect.height - height) / 2);
  }
  return {
    left: left - frameRect.left,
    top: top - frameRect.top,
    width,
    height
  };
}

function syncHeroEvidenceLayer() {
  const layer = document.getElementById("heroEvidenceLayer");
  const box = displayedHeroImageBox();
  if (!layer || !box) return null;
  layer.style.left = `${box.left}px`;
  layer.style.top = `${box.top}px`;
  layer.style.width = `${box.width}px`;
  layer.style.height = `${box.height}px`;
  return box;
}

function sessionImpacts(session) {
  const impacts = Array.isArray(session && session.impactPoints)
    ? session.impactPoints
    : (Array.isArray(session && session.shotData && session.shotData.impactPoints) ? session.shotData.impactPoints : []);
  return impacts.map(safePoint).filter(Boolean);
}

function sessionAim(session) {
  return safePoint((session && session.aimPoint) || (session && session.shotData && session.shotData.aimPoint));
}

function sessionCorrection(session, aim, impacts) {
  if (session && session.clicks && session.clicks.poib) return session.clicks;
  if (aim && impacts.length) return SCZN3M4.calculateTapCorrection(aim, impacts);
  return null;
}

function sessionEvidencePackage(session) {
  const aim = sessionAim(session);
  const impacts = sessionImpacts(session);
  const correction = sessionCorrection(session, aim, impacts);
  const poib = safePoint(correction && correction.poib);
  if (!session || !aim || !impacts.length || !correction || !poib) return null;
  return {
    session,
    aim,
    impacts,
    correction,
    poib,
    image: (session.targetEvidenceImage && session.targetEvidenceImage.dataUrl) || HOME_CONFIG.targetImage
  };
}

function latestEvidencePackage() {
  const sessions = SCZN3M4.getSessionHistory ? SCZN3M4.getSessionHistory() : [];
  for (const session of sessions) {
    const evidence = sessionEvidencePackage(session);
    if (evidence) return evidence;
  }
  return null;
}

function approvedFallbackEvidencePackage() {
  const fallback = HOME_CONFIG.approvedFallbackEvidence;
  if (!fallback) return null;
  const aim = safePoint(fallback.aim);
  const impacts = (fallback.impacts || []).map(safePoint).filter(Boolean);
  const correction = aim && impacts.length ? SCZN3M4.calculateTapCorrection(aim, impacts) : null;
  const poib = safePoint(correction && correction.poib);
  if (!aim || !poib || !impacts.length || !correction) return null;
  return {
    session: {
      sessionLabel: "Baker Preview",
      matrixSnapshot: {
        modelCaliber: "Baker ST-100YD-SMART",
        targetDistance: fallback.distance
      },
      shotData: {
        shotCount: impacts.length,
        hits: impacts.length,
        groupSize: fallback.group,
        poibSummary: fallback.poibSummary
      }
    },
    isFallback: true,
    aim,
    impacts,
    poib,
    correction,
    image: HOME_CONFIG.fallbackEvidenceImage || HOME_CONFIG.targetImage,
    display: {
      distance: fallback.distance,
      hits: fallback.hits
    }
  };
}

function heroEvidencePackage() {
  return latestEvidencePackage() || approvedFallbackEvidencePackage();
}

function sessionDistance(session) {
  const snapshot = session && session.matrixSnapshot ? session.matrixSnapshot : {};
  return String((session && (session.targetDistance || session.distance)) || snapshot.targetDistance || snapshot.distance || "100 yds").toUpperCase();
}

function formatDate(value) {
  if (!value) return "Recent session";
  return new Date(value).toLocaleString(undefined, {
    month: "short",
    day: "numeric",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit"
  });
}

function sessionToCard(session, index) {
  const snapshot = session && session.matrixSnapshot ? session.matrixSnapshot : {};
  const shotData = session && session.shotData ? session.shotData : {};
  const correction = session && session.correctionData ? session.correctionData : {};
  const fallbackEvidence = index === 0 ? approvedFallbackEvidencePackage() : null;
  const evidence = sessionEvidencePackage(session) || (!session ? fallbackEvidence : null);
  return {
    session,
    evidence,
    title: session ? (session.sessionLabel || SCZN3M4.formatSessionNumber(session.sessionNumber)) : (fallbackEvidence ? "Baker Evidence Preview" : HOME_CONFIG.examples[index].title),
    date: session ? formatDate(session.timestamp || session.createdAt) : (fallbackEvidence ? "Approved fallback evidence" : HOME_CONFIG.examples[index].date),
    weapon: snapshot.modelCaliber || snapshot.rifle || (fallbackEvidence ? "Baker ST-100YD-SMART" : HOME_CONFIG.examples[index].weapon),
    distance: snapshot.targetDistance || snapshot.distance || (fallbackEvidence ? HOME_CONFIG.approvedFallbackEvidence.distance : HOME_CONFIG.examples[index].distance),
    shots: `${shotData.shotCount || shotData.hits || (fallbackEvidence ? fallbackEvidence.impacts.length : HOME_CONFIG.examples[index].shots.replace(/\D/g, "") || 5)} Shots`,
    group: session && shotData.groupSize ? shotData.groupSize : (fallbackEvidence ? HOME_CONFIG.approvedFallbackEvidence.group : HOME_CONFIG.examples[index].group),
    poib: session && shotData.poibSummary ? shotData.poibSummary : (fallbackEvidence ? HOME_CONFIG.approvedFallbackEvidence.poibSummary : HOME_CONFIG.examples[index].poib)
  };
}

function renderLandingCorrectionCard() {
  const evidence = heroEvidencePackage();
  const card = document.getElementById("landingCorrectionCard");
  const image = document.getElementById("heroTargetImage");
  const layer = document.getElementById("heroEvidenceLayer");
  if (!card || !image || !layer) return;

  const normalizedEvidence = evidence ? SCZN3M4.UGEO.normalizeEvidencePackage(evidence) : null;
  image.src = normalizedEvidence ? normalizedEvidence.targetImage : (HOME_CONFIG.fallbackEvidenceImage || HOME_CONFIG.targetImage);
  layer.textContent = "";
  card.classList.add("is-hidden");

  const render = () => {
    syncHeroEvidenceLayer();
    if (!normalizedEvidence) return;
    const { correction, impacts } = normalizedEvidence;
    console.log("UGEO regression check", SCZN3M4.UGEO.regressionCheck(normalizedEvidence));
    layer.innerHTML = SCZN3M4.UGEO.renderEvidenceUGEO(normalizedEvidence, {
      vectorClass: "hero-correction-vector",
      impactClass: "hero-impact-dot",
      impactNumbered: true,
      aimClass: "hero-aim-dot",
      poibClass: "hero-poib-dot"
    });
    document.getElementById("landingDistance").textContent = normalizedEvidence.display ? normalizedEvidence.display.distance : (normalizedEvidence.distance || sessionDistance(normalizedEvidence.session));
    document.getElementById("landingElevation").textContent = compactClick(correction && correction.elevation, "elevation");
    document.getElementById("landingWindage").textContent = compactClick(correction && correction.windage, "windage");
    document.getElementById("landingHits").textContent = normalizedEvidence.display ? normalizedEvidence.display.hits : `${impacts.length} Hits`;
    card.classList.remove("is-hidden");
  };

  if (image.complete) {
    requestAnimationFrame(render);
  } else {
    image.addEventListener("load", () => requestAnimationFrame(render), { once: true });
  }
}

function renderRecentThumb(card) {
  if (!card.evidence) {
    return `
      <div class="recent-thumb" aria-hidden="true">
        <img src="${HOME_CONFIG.targetImage}" alt="" />
      </div>`;
  }
  const evidence = SCZN3M4.UGEO.normalizeEvidencePackage(card.evidence);
  return `
    <div class="recent-thumb has-session-evidence" aria-hidden="true">
      <img src="${evidence.targetImage}" alt="" />
      ${SCZN3M4.UGEO.renderEvidenceUGEO(evidence, {
        vectorClass: "recent-thumb-vector",
        impactClass: "recent-thumb-hole is-real",
        aimClass: "recent-thumb-aim",
        poibClass: "recent-thumb-poib"
      })}
    </div>`;
}

function renderRecentCards() {
  const sessions = (SCZN3M4.getSessionHistory ? SCZN3M4.getSessionHistory() : []).slice(0, 3);
  const cards = [0, 1, 2].map(index => sessionToCard(sessions[index], index));
  const grid = document.getElementById("recentSecGrid");
  grid.textContent = "";
  cards.forEach((card, index) => {
    const article = document.createElement("article");
    article.className = "recent-card";
    article.innerHTML = `
      ${renderRecentThumb(card)}
      <div class="recent-copy">
        <strong>${card.title}</strong>
        <span>${card.date}</span>
        <span>✦ ${card.weapon}</span>
        <span>◉ ${card.distance}</span>
        <span>● ${card.shots}</span>
        <p>Group: <b>${card.group}</b><br />POIB: <b>${card.poib}</b></p>
      </div>`;
    if (index === 0) article.classList.add("is-mirror");
    grid.append(article);
  });
}

renderLandingCorrectionCard();
renderRecentCards();
window.addEventListener("resize", () => syncHeroEvidenceLayer());
</script>
